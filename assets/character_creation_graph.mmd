flowchart TD
    START([START]) --> validate[validate]

    validate -->|"decide(): llm_persona 항상 fan-out"| llm_persona["llm_persona<br/><i>RetryPolicy(max=3, LLMFailedError)</i>"]
    validate -->|"image_and_text:<br/>source_image 있음"| source_upload["source_upload<br/><i>RetryPolicy(max=4, S3UploadFailedError)</i>"]
    validate -->|"text_only:<br/>source_image 없음"| vlm_skip["vlm_skip<br/><i>no-op (fan-in 정렬용)</i>"]

    source_upload --> vlm_analyzer[vlm_analyzer]
    vlm_analyzer --> image_generator
    vlm_skip --> image_generator
    llm_persona --> image_generator[image_generator]

    image_generator -->|"state.error is None"| generated_upload[generated_upload]
    image_generator -->|"state.error"| cleanup_source_image[cleanup_source_image]

    generated_upload -->|"state.error is None"| builder[builder]
    generated_upload -->|"state.error"| cleanup_source_image

    builder -->|"state.error is None"| END_OK([END])
    builder -->|"state.error"| cleanup_source_image

    cleanup_source_image --> END_ERR([END])

    classDef startend fill:#1f2937,stroke:#111827,color:#fff
    classDef happy fill:#dbeafe,stroke:#1d4ed8,color:#1e3a8a
    classDef compensation fill:#fee2e2,stroke:#b91c1c,color:#7f1d1d
    classDef noop fill:#f3f4f6,stroke:#9ca3af,color:#374151,stroke-dasharray: 4 2

    class START,END_OK,END_ERR startend
    class validate,llm_persona,source_upload,vlm_analyzer,image_generator,generated_upload,builder happy
    class cleanup_source_image compensation
    class vlm_skip noop
