---
config:
  layout: elk
---
flowchart TB
    A[/"Input
    FeedGenerationInput
    (quest, character + image_url)"/]

    A --> VAL["validate
    character.image_url 비어있으면 InputValidationError"]

    VAL --> CTX1["assemble_image_prompt
    appearance_keywords + quest_text
    → image_prompt (텍스트)"]

    CTX1 --> IMG{{"img2img
    기준 이미지 + image_prompt
    → raw_image (bytes)
    RetryPolicy max=3"}}

    IMG --> S3{{"s3_upload
    raw_image → S3 업로드
    → image_url
    RetryPolicy max=3"}}

    S3 --> CTX2["assemble_caption_ctx
    quest + 캐릭터 말투/페르소나 + image_prompt
    → caption_ctx (LLM 프롬프트)"]

    CTX2 --> LLM{{"llm_caption
    Mi:dm LLM
    → raw_caption (한글)
    RetryPolicy max=3"}}

    LLM --> VCHK["validate_caption
    len ≤ 140 · 한글 포함 여부
    CaptionValidationError (재시도 없음)"]

    VCHK --> BUILD["builder
    character_id + quest_id + image_url + caption
    → GeneratedFeed"]

    BUILD --> OUT[/"Output
    GeneratedFeed"/]

    classDef input fill:#fef9c3,stroke:#ca8a04,color:#713f12
    classDef process fill:#ffffff,stroke:#6b7280,color:#111827
    classDef ai fill:#f5f3ff,stroke:#7c3aed,color:#4c1d95
    classDef gate fill:#fed7aa,stroke:#ea580c,color:#7c2d12

    A:::input
    OUT:::input
    VAL:::process
    CTX1:::process
    IMG:::ai
    S3:::process
    CTX2:::process
    LLM:::ai
    VCHK:::gate
    BUILD:::process